@namespace BlazorBlobExplorer.Shared
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="app-shell">
    <header class="topbar">
        <div class="topbar-left">
            <span class="topbar-logo">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    <polyline points="9 22 9 12 15 12 15 22"/>
                </svg>
            </span>
            <span class="topbar-title">Blob Explorer</span>
        </div>
        <div class="topbar-right">
            <AuthorizeView>
                <Authorized>
                    <span class="user-name">@context.User.Identity?.Name</span>
                    <button class="btn-signout" @onclick="SignOut">Sign out</button>
                </Authorized>
            </AuthorizeView>
        </div>
    </header>
    <main class="main-content">
        @Body
    </main>
</div>

@code {
    private void SignOut() =>
        Navigation.NavigateTo("/.auth/logout?post_logout_redirect_uri=/", forceLoad: true);
}

{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_framework/*", "*.{js,map,css,png,ico,json,wasm,dat,blat}"]
  },
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    }
  }
}
